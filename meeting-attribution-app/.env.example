# ── HubSpot ──────────────────────────────────────────────────────────────────
# Private App token (Settings → Integrations → Private Apps)
HUBSPOT_ACCESS_TOKEN=pat-na1-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# ── Slack ─────────────────────────────────────────────────────────────────────
# Bot User OAuth Token (starts with xoxb-)
SLACK_BOT_TOKEN=xoxb-xxxxxxxxxxxx-xxxxxxxxxxxx-xxxxxxxxxxxxxxxxxxxxxxxx
# Signing Secret (used to verify request signatures from Slack)
SLACK_SIGNING_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── App Home Dashboard ────────────────────────────────────────────────────────
# Email of the admin who sees ALL messages in the App Home tab.
# Other users only see their own messages. Leave blank to disable admin view.
ADMIN_EMAIL=

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3000
